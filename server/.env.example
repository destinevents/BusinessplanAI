# ── Claude (Anthropic) ─────────────────────────────────────────────────────────
# Get a key from console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Database (Neon: neon.tech → New Project → copy Connection String) ──────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex-string
JWT_EXPIRES_IN=7d

# ── Admin ──────────────────────────────────────────────────────────────────────
# Used to gate POST /api/admin/grant-credits (also requires isAdmin=true on user)
ADMIN_SECRET=replace-with-strong-secret

# ── CORS ───────────────────────────────────────────────────────────────────────
# Exact origin of your deployed frontend — no trailing slash
FRONTEND_ORIGIN=https://your-app.vercel.app

# ── Credit constants (change without redeploying) ──────────────────────────────
STARTING_CREDITS=3
PLAN_CREDIT_COST=1

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
